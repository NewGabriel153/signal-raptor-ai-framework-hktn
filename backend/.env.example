# ── App ─────────────────────────────────────────────
APP_TITLE=Signal Raptor Agentic Framework API
APP_VERSION=0.1.0
ECHO_SQL=false

# ── PostgreSQL ──────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydatabase
# DATABASE_URL=               # optional override; takes precedence over individual POSTGRES_* vars

# ── Redis / ARQ ────────────────────────────────────
# REDIS_URL=                  # optional override; takes precedence over individual REDIS_* vars
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=             # uncomment if your Redis instance requires auth
ARQ_QUEUE_NAME=signal-raptor-runs
ARQ_MAX_JOBS=10

# ── LLM Provider Keys ─────────────────────────────
# At least one key is needed to run agent sessions
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_REQUEST_TIMEOUT=120