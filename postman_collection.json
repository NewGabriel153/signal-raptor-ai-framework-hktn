        {
          "name": "Delete Tool",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/v1/tools/{{tool_id}}",
            "description": "Delete one tool by UUID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Agent Tools",
      "item": [
        {
          "name": "Assign Tool To Agent",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/v1/agents/{{agent_id}}/tools/{{tool_id}}",
            "description": "Associate an existing tool with an existing agent."
          },
          "response": []
        },
        {
          "name": "List Agent Tools",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/agents/{{agent_id}}/tools",
            "description": "List all tools currently assigned to the selected agent."
          },
          "response": []
        },
        {
          "name": "Remove Tool From Agent",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/v1/agents/{{agent_id}}/tools/{{tool_id}}",
            "description": "Remove a tool assignment from an agent."
          },
          "response": []
