            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Use any available tools to solve 12 multiplied by 8 and explain the answer.\"\n}"
            },
            "url": "{{base_url}}/api/v1/sessions/{{session_id}}/run",
            "description": "Invoke the streaming session execution endpoint. This path is partially implemented and requires a valid provider adapter configuration to exercise real model behavior."
          },
          "response": []
        }
      ]
    }
