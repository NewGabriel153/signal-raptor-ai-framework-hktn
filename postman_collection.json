          },
          "response": []
        },
        {
          "name": "Update Tool",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Performs arithmetic for agent tool calls.\"\n}"
            },
            "url": "{{base_url}}/api/v1/tools/{{tool_id}}",
            "description": "Update a subset of tool metadata."
          },
          "response": []
