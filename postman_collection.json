    },
    {
      "name": "Runs",
      "item": [
        {
          "name": "Enqueue Run",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"{{agent_id}}\",\n  \"prompt\": \"Summarize the current deployment status and list any blockers.\"\n}"
            },
            "url": "{{base_url}}/api/v1/runs/",
            "description": "Queue a background run for the selected agent. Saves the returned session id into both session_id and run_id collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 202\", function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "const payload = pm.response.json();",
                  "if (payload.session_id) {",
                  "    pm.collectionVariables.set(\"session_id\", payload.session_id);",
                  "    pm.collectionVariables.set(\"run_id\", payload.session_id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Run",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/runs/{{run_id}}",
            "description": "Fetch session status and execution logs for a queued run."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Run Session Stream",
          "request": {
